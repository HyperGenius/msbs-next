{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.*_cache": true,
        "**/__pycache__": true,
        "backend/.venv": true,
    },
    "editor.definitionLinkOpensInPeek": true, // 定義をポップアップで表示
    "editor.cursorSmoothCaretAnimation": "on", // カーソルの動きを滑らかにして視認性UP
    "cSpell.customDictionaries": {
        "project-words": {
            "name": "project-words",
            "path": "${workspaceFolder}/.vscode/project-words.txt",
            "addWords": true
        }
    }
}