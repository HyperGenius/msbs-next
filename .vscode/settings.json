{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/.*_cache": true,
        "**/__pycache__": true,
        "backend/.venv": true,
    },
    "editor.definitionLinkOpensInPeek": true, // 定義をポップアップで表示
    "editor.cursorSmoothCaretAnimation": "on", // カーソルの動きを滑らかにして視認性UP
    "cSpell.dictionaries": [
        "python",
        "typescript",
        "softwareTerms"
    ],
    "cSpell.customDictionaries": {
        "msbs-words": {
            "name": "msbs-words",
            "path": "${workspaceRoot}/.vscode/msbs-words.txt",
            "description": "MSBSプロジェクトでよく使われる単語を含むカスタム辞書",
            "addWords": true
        }
    },
    "mypy-type-checker.args": [
        "\"mypy-type-chekcer.args\" : [\"--confit-file=./pyproject.toml\"]"
    ]
}